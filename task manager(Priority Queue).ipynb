     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Task Execution Order:\n",
      "Email check - Priority 1\n",
      "Security update - Priority 2\n",
      "Database backup - Priority 3\n"
     ]
    }
   ],
   "source": [
    "import heapq\n",
    "tasks = []\n",
    "heapq.heappush(tasks, (3, \"Database backup\"))\n",
    "heapq.heappush(tasks, (1, \"Email check\"))\n",
    "heapq.heappush(tasks, (2, \"Security update\"))\n",
    "print(\"Task Execution Order:\")\n",
    "while tasks:\n",
    "    priority, task = heapq.heappop(tasks)\n",
    "    print(task, \"- Priority\", priority)"
   ]
  },
